# ============================================================
# .env.example — このファイルをコピーして .env を作成してください
# cp .env.example .env
#
# .env には機密情報が含まれるため、絶対にコミット・pushしないこと
# ============================================================

# ------------------------------------------------------------
# Jira
# API トークンの発行: https://id.atlassian.com/manage-profile/security/api-tokens
# ------------------------------------------------------------
JIRA_BASE_URL=https://your-domain.atlassian.net

# 個人アカウント（account_mode: personal のとき使用）
JIRA_EMAIL_PERSONAL=your-personal-email@example.com
JIRA_API_TOKEN_PERSONAL=your_personal_api_token

# サービスアカウント（account_mode: service のとき使用）
JIRA_EMAIL_SERVICE=service-account@your-domain.atlassian.net
JIRA_API_TOKEN_SERVICE=your_service_api_token

# ------------------------------------------------------------
# Confluence
# API トークンは Jira と共通（同じ Atlassian アカウント）
# ------------------------------------------------------------
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net

# 個人アカウント（account_mode: personal のとき使用）
CONFLUENCE_EMAIL_PERSONAL=your-personal-email@example.com
CONFLUENCE_API_TOKEN_PERSONAL=your_personal_api_token

# サービスアカウント（account_mode: service のとき使用）
CONFLUENCE_EMAIL_SERVICE=service-account@your-domain.atlassian.net
CONFLUENCE_API_TOKEN_SERVICE=your_service_api_token

# ------------------------------------------------------------
# Slack
# Bot Token の取得: https://api.slack.com/apps → OAuth & Permissions
# 必要な権限スコープ: chat:write, channels:read, files:write, users:read
# ------------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-your-bot-token

# ------------------------------------------------------------
# Microsoft Graph API（Excel / OneDrive / SharePoint アクセス用）
# Azure Portal でアプリ登録後に取得: https://portal.azure.com
# 必要な API 権限: Files.ReadWrite.All（アプリケーション権限）
# ------------------------------------------------------------
MS_GRAPH_CLIENT_ID=your-client-id
MS_GRAPH_CLIENT_SECRET=your-client-secret
MS_GRAPH_TENANT_ID=your-tenant-id

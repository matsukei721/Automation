# ============================================================
# .env.example — このファイルをコピーして .env を作成してください
# cp .env.example .env
#
# .env には機密情報が含まれるため、絶対にコミット・pushしないこと
# ============================================================

# ============================================================
# Jira / Confluence
# API トークンの発行: https://id.atlassian.com/manage-profile/security/api-tokens
#
# 最小権限の原則に基づき、READ / WRITE スコープに分離してください
# - READ スコープ: Issue・ページの参照のみ必要な場合
# - WRITE スコープ: Issue 作成・更新・コメント追加が必要な場合
# ============================================================

JIRA_BASE_URL=https://your-domain.atlassian.net
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net

# ────────────────────────────────────────────────────────
# 個人アカウント — READ スコープ（参照のみ）
# ────────────────────────────────────────────────────────
JIRA_EMAIL_PERSONAL_READ=your-personal-email@example.com
JIRA_API_TOKEN_PERSONAL_READ=your_personal_read_api_token

CONFLUENCE_EMAIL_PERSONAL_READ=your-personal-email@example.com
CONFLUENCE_API_TOKEN_PERSONAL_READ=your_personal_read_api_token

# ────────────────────────────────────────────────────────
# 個人アカウント — WRITE スコープ（読取・作成・更新・コメント）
# ────────────────────────────────────────────────────────
JIRA_EMAIL_PERSONAL_WRITE=your-personal-email@example.com
JIRA_API_TOKEN_PERSONAL_WRITE=your_personal_write_api_token

CONFLUENCE_EMAIL_PERSONAL_WRITE=your-personal-email@example.com
CONFLUENCE_API_TOKEN_PERSONAL_WRITE=your_personal_write_api_token

# ────────────────────────────────────────────────────────
# サービスアカウント — READ スコープ（参照のみ）
# ────────────────────────────────────────────────────────
JIRA_EMAIL_SERVICE_READ=service-account@your-domain.atlassian.net
JIRA_API_TOKEN_SERVICE_READ=your_service_read_api_token

CONFLUENCE_EMAIL_SERVICE_READ=service-account@your-domain.atlassian.net
CONFLUENCE_API_TOKEN_SERVICE_READ=your_service_read_api_token

# ────────────────────────────────────────────────────────
# サービスアカウント — WRITE スコープ（読取・作成・更新・コメント）
# ────────────────────────────────────────────────────────
JIRA_EMAIL_SERVICE_WRITE=service-account@your-domain.atlassian.net
JIRA_API_TOKEN_SERVICE_WRITE=your_service_write_api_token

CONFLUENCE_EMAIL_SERVICE_WRITE=service-account@your-domain.atlassian.net
CONFLUENCE_API_TOKEN_SERVICE_WRITE=your_service_write_api_token

# ============================================================
# Slack
# Bot Token の取得: https://api.slack.com/apps → OAuth & Permissions
# 必要な権限スコープ: chat:write, channels:read, files:write, users:read
# ============================================================
SLACK_BOT_TOKEN=xoxb-your-bot-token

# ============================================================
# Microsoft Graph API（Excel / OneDrive / SharePoint アクセス用）
# Azure Portal でアプリ登録後に取得: https://portal.azure.com
# 必要な API 権限: Files.ReadWrite.All（アプリケーション権限）
#
# 用途に応じて以下の権限を検討してください:
# - Files.Read.All: ファイル参照のみ
# - Files.ReadWrite.All: ファイル読み書き（推奨・デフォルト）
# ============================================================
MS_GRAPH_CLIENT_ID=your-client-id
MS_GRAPH_CLIENT_SECRET=your-client-secret
MS_GRAPH_TENANT_ID=your-tenant-id
